# =============================================================================
# video_system/.gitignore
# =============================================================================
# This file protects the video_system from accidentally committing large media
# files, renders, and machine-specific Resolve project data.
#
# Philosophy:
# - Git tracks: code, tools, templates, plans, docs, and small assets.
# - Git does NOT track: raw footage, large b-roll, renders, work files,
#   and full Resolve project databases.
#
# See docs/MEDIA_AND_GIT_STRATEGY.md for the full cross-device workflow.
# =============================================================================

# --- Large Media & Source Assets (NEVER commit these) ---
assets/**/*.mp4
assets/**/*.mov
assets/**/*.mkv
assets/**/*.avi
assets/**/*.webm
assets/**/*.wav
assets/**/*.aif
assets/**/*.aiff
assets/**/*.flac
assets/**/*.mp3
assets/**/CIRI*.pdf
assets/**/CIRI*Journal*/
assets/**/*.jpg
assets/**/*.jpeg
assets/**/*.png
assets/**/*.webp
assets/**/*.tiff
assets/**/*.tif

# Allow small, intentional template/branding assets that are part of the visual system
!assets/logo_square.png
!assets/show_image.png
!assets/show_image_lower_third.png
!assets/intro.mp4          # Usually small branded intro — review case-by-case
!assets/music.wav          # Usually small music sting

# --- Render Outputs & Intermediate Work ---
renders/**
work/**
previews/**
*.raw.mp4
*.mixed.mp4
final_*.mp4
draft_*.mp4

# --- Resolve-specific (machine-specific or very large) ---
*.drp
Resolve Projects/
*.resolve
*.db
*.sqlite
*.lock
CacheClip/
*.r3d
*.braw

# --- Planning artifacts that can be large or contain local paths ---
# We generally WANT video_plan.xlsx and .json in git.
# Only ignore if they become problematic.
# planning/video_plan.xlsx
# planning/video_plan.json

# --- Captions & Transcripts (usually fine to keep) ---
# planning/captions.*
# planning/*.srt
# planning/*.vtt
# planning/*.ass

# --- Generated / Temporary ---
__pycache__/
*.py[cod]
*.log
.DS_Store
Thumbs.db
*.tmp
*.bak

# Office / Excel lock and copy files (common when files are open)
~$*
* - Copy.*
* - Copy *.*
~$*.xlsx
~$*.xls*

# --- Per-project large client data (defense in depth) ---
# Ignore entire asset, render, work dirs under any project (robust glob)
projects/**/assets/
projects/**/renders/
projects/**/work/
projects/**/previews/
projects/**/social/
projects/**/Hooks/
projects/**/Shorts/

# --- Regenerable parlay artifacts ---
# parlay_state.json is a READ-ONLY runtime mirror of the DB state (see
# app/parlay_state.py). It is rewritten on every tool call — never source.
projects/**/parlay_state.json
# Spreadsheet backup snapshots written before edits (scratch, not source).
projects/**/*.before_*.xlsx

# Keep the _starter_project minimal
!projects/_starter_project/assets/*.png
!projects/_starter_project/assets/*.wav
!projects/_starter_project/assets/intro.mp4
!projects/_starter_project/assets/music.wav

# --- Environment / Secrets ---
.env
.env.*
*.key
*.pem
secrets/

# Note: Individual projects may add their own .gitignore entries for
# extremely large one-off assets. Prefer using this root video_system/.gitignore.
# Store these as Azure Container App secrets or Key Vault secrets.
# Never commit real values.

DATABASE_URL=
PROJECT_MEMORY_ENABLED=true

LLM_PROVIDER=grok
LLM_TEMPERATURE=0.2
XAI_API_KEY=
GROK_MODEL=grok-4.3
GROK_API_BASE=https://api.x.ai/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

ALLOWED_ORIGINS=

MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_GRAPH_SCOPE=https://graph.microsoft.com/.default
MICROSOFT_WEBHOOK_CLIENT_STATE=
MICROSOFT_GRAPH_ALLOW_SEND=false
ONENOTE_OWNER_MAILBOX=
ONENOTE_NOTEBOOK_ID=
ONENOTE_NOTEBOOK_NAME=RamAir
ONENOTE_SECTION_ID=
ONENOTE_SECTION_NAME=Meeting Notes
# Per-client Teams team_id / channel_id / template_path live in
# client_artifacts/<client_id>/config.yaml (not env vars).
M365_FILES_DRIVE_ID=
M365_FILES_FOLDER_ITEM_ID=
M365_FILES_BASE_PATH=03_Deliverables/Meeting Notes

# Fallback client when Tavus call has no X-Parlayvu-Client-Id header.
NATHAN_DEFAULT_CLIENT_ID=ramair

TEAMS_APP_ID=
TEAMS_APP_PASSWORD=
TEAMS_TENANT_ID=
TEAMS_WEBHOOK_SECRET=

NATHAN_MAILBOX=
ALEX_MAILBOX=
AVA_MAILBOX=
BLAKE_MAILBOX=
CASEY_MAILBOX=
CODEY_MAILBOX=
DYLAN_MAILBOX=
JORDAN_MAILBOX=
MICHAEL_MAILBOX=
MORGAN_MAILBOX=
NORA_MAILBOX=
RILEY_MAILBOX=
TAYLOR_MAILBOX=

# Tavus CVI — chosen avatar provider (HeyGen evaluated and removed Phase 2)
TAVUS_API_KEY=
TAVUS_REPLICA_ID=
TAVUS_PERSONA_ID=
TAVUS_REPLICA_ID_NATHAN=

# ── parlayvu.ai customer login + subscription ───────────────────────────────
# Public https URL of the deployed app; used to build magic-link + Stripe
# redirect URLs. Must match the container app FQDN (or your custom domain).
APP_BASE_URL=
# Random high-entropy secret. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=
# Stripe LIVE secret key in production (sk_live_...). Create the recurring
# $800/4-week price in LIVE mode (python scripts/setup_stripe.py) and paste id.
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
# From the LIVE webhook endpoint (https://<fqdn>/webhooks/stripe) signing secret.
STRIPE_WEBHOOK_SECRET=
# Resend API key + a verified sender for magic-link sign-in emails.
RESEND_API_KEY=
EMAIL_FROM=ParlayVU <login@parlayvu.ai>

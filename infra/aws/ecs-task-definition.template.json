{
  "family": "parlayvu-core",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::<account-id>:role/parlayvu-ecs-task-execution-role",
  "taskRoleArn": "arn:aws:iam::<account-id>:role/parlayvu-ecs-task-role",
  "containerDefinitions": [
    {
      "name": "api",
      "image": "<account-id>.dkr.ecr.<region>.amazonaws.com/parlayvu-core:<image-tag>",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8000,
          "hostPort": 8000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "HOST", "value": "0.0.0.0" },
        { "name": "PORT", "value": "8000" },
        { "name": "UVICORN_RELOAD", "value": "false" },
        { "name": "LOG_LEVEL", "value": "INFO" },
        { "name": "PROJECT_MEMORY_ENABLED", "value": "true" },
        { "name": "MICROSOFT_GRAPH_ALLOW_SEND", "value": "false" },
        { "name": "AWS_REGION", "value": "<region>" }
      ],
      "secrets": [
        { "name": "DATABASE_URL", "valueFrom": "arn:aws:secretsmanager:<region>:<account-id>:secret:/parlayvu/prod/DATABASE_URL" },
        { "name": "LLM_PROVIDER", "valueFrom": "arn:aws:secretsmanager:<region>:<account-id>:secret:/parlayvu/prod/LLM_PROVIDER" },
        { "name": "XAI_API_KEY", "valueFrom": "arn:aws:secretsmanager:<region>:<account-id>:secret:/parlayvu/prod/XAI_API_KEY" },
        { "name": "OPENAI_API_KEY", "valueFrom": "arn:aws:secretsmanager:<region>:<account-id>:secret:/parlayvu/prod/OPENAI_API_KEY" },
        { "name": "GROQ_API_KEY", "valueFrom": "arn:aws:secretsmanager:<region>:<account-id>:secret:/parlayvu/prod/GROQ_API_KEY" },
        { "name": "MICROSOFT_TENANT_ID", "valueFrom": "arn:aws:secretsmanager:<region>:<account-id>:secret:/parlayvu/prod/MICROSOFT_TENANT_ID" },
        { "name": "MICROSOFT_CLIENT_ID", "valueFrom": "arn:aws:secretsmanager:<region>:<account-id>:secret:/parlayvu/prod/MICROSOFT_CLIENT_ID" },
        { "name": "MICROSOFT_CLIENT_SECRET", "valueFrom": "arn:aws:secretsmanager:<region>:<account-id>:secret:/parlayvu/prod/MICROSOFT_CLIENT_SECRET" },
        { "name": "TEAMS_APP_ID", "valueFrom": "arn:aws:secretsmanager:<region>:<account-id>:secret:/parlayvu/prod/TEAMS_APP_ID" },
        { "name": "TEAMS_APP_PASSWORD", "valueFrom": "arn:aws:secretsmanager:<region>:<account-id>:secret:/parlayvu/prod/TEAMS_APP_PASSWORD" },
        { "name": "HEYGEN_API_KEY", "valueFrom": "arn:aws:secretsmanager:<region>:<account-id>:secret:/parlayvu/prod/HEYGEN_API_KEY" }
      ],
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -fsS http://127.0.0.1:8000/health || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 20
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/parlayvu-core",
          "awslogs-region": "<region>",
          "awslogs-stream-prefix": "api"
        }
      }
    }
  ]
}

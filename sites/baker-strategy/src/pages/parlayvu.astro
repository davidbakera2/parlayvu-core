---
import Layout from "@/layouts/Layout.astro";
import SiteNav from "@/components/SiteNav.astro";
import RamAirCaseStudy from "@/components/RamAirCaseStudy.astro";

const year = new Date().getFullYear();

const capabilities = [
  "AI agents for content parlay (1 → many channels)",
  "Automated social, email, SEO & paid distribution",
  "Strategic oversight by Nathan Ellis (Orchestrator)",
  "Web & deployment by Dylan Brooks",
  "Design systems by Alex Rivera",
];
---

<Layout
  title="ParlayVU | Baker Strategy"
  description="Baker Strategy partners with ParlayVU for AI-powered content amplification and multi-channel reach."
>
  <div class="min-h-screen bg-zinc-950 text-white">
    <SiteNav />

    <section class="pt-20 pb-16">
      <div class="max-w-5xl mx-auto px-6 text-center">
        <div class="inline-block px-4 py-1.5 rounded-full bg-blue-600/10 text-blue-400 text-sm font-medium mb-6">
          Baker Strategy Initiative
        </div>
        <h1 class="text-6xl md:text-7xl font-semibold tracking-tighter leading-none mb-6">ParlayVU</h1>
        <p class="text-2xl text-blue-400 mb-8">AI Agents That Parlay Your Content Into Multi-Channel Reach</p>
        <p class="max-w-2xl mx-auto text-lg text-zinc-400">
          Baker Strategy partners with ParlayVU to supercharge your market strategy with cutting-edge AI agents. From
          content amplification to automated multi-channel campaigns, ParlayVU turns your message into momentum.
        </p>
      </div>
    </section>

    <section class="py-16 border-t border-zinc-800">
      <div class="max-w-5xl mx-auto px-6">
        <div class="grid md:grid-cols-2 gap-16 items-center">
          <div>
            <h2 class="text-4xl font-semibold tracking-tighter mb-6">What is ParlayVU?</h2>
            <div class="space-y-4 text-lg text-zinc-400">
              <p>
                ParlayVU is an AI-powered content amplification system that takes your core message and intelligently
                distributes it across multiple channels.
              </p>
              <p>
                Built by the same team behind Baker Strategy, it combines strategic thinking with autonomous AI
                execution.
              </p>
            </div>
          </div>
          <div class="bg-zinc-900 rounded-3xl p-10 border border-zinc-800">
            <h3 class="font-semibold text-xl mb-6">Core Capabilities</h3>
            <ul class="space-y-4 text-zinc-400">
              {
                capabilities.map((item) => (
                  <li class="flex gap-3">
                    <span class="text-blue-400" aria-hidden="true">•</span>
                    <span>{item}</span>
                  </li>
                ))
              }
            </ul>
          </div>
        </div>
      </div>
    </section>

    <RamAirCaseStudy />

    <section class="py-20 bg-zinc-900 border-t border-zinc-800">
      <div class="max-w-4xl mx-auto px-6 text-center">
        <h2 class="text-4xl font-semibold tracking-tighter mb-8">Why Baker Strategy + ParlayVU?</h2>
        <p class="text-2xl text-zinc-300">Strategy + AI = Exponential Growth</p>
        <p class="mt-4 text-lg text-zinc-400 max-w-xl mx-auto">
          Your market plan, executed at scale with intelligent automation and human oversight.
        </p>
      </div>
    </section>

    <section class="py-20 border-t border-zinc-800">
      <div class="max-w-xl mx-auto px-6 text-center">
        <h3 class="text-3xl font-semibold tracking-tight mb-4">Ready to integrate ParlayVU?</h3>
        <p class="text-zinc-400 mb-8">Let's discuss how AI agents can amplify your strategy.</p>
        <a
          href="/#contact"
          class="inline-flex h-14 items-center justify-center px-10 rounded-3xl bg-white text-black font-semibold hover:bg-blue-600 hover:text-white transition-all"
        >
          Talk to Us About ParlayVU
        </a>
      </div>
    </section>

    <footer class="border-t border-zinc-800 py-8 text-center text-sm text-zinc-500">
      © {year} Baker Strategy LLC · Powered by ParlayVU
    </footer>
  </div>
</Layout>

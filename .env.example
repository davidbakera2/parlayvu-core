# ============================================================================
# ParlayVU API — environment template
# ============================================================================
# Copy to .env and fill in real values. .env is gitignored.
# See SETUP.md for the canonical list of what each block configures.
#
# Two distinct Azure AD identities are used:
#   - MICROSOFT_*  → Microsoft Graph app (mail, OneNote, Teams files)
#   - TEAMS_APP_*  → Bot Framework app (Teams bot identity)
# These may be the SAME app registration in development. In production they
# are commonly separate to scope risk. Either way, do not consolidate the
# names — they represent different concepts.
# ============================================================================

# ── LLM provider (orchestrator default) ──────────────────────────────────────
# Per-agent overrides live in app/settings.py:build_agent_model_map.
LLM_PROVIDER=grok
LLM_TEMPERATURE=0.2

# xAI Grok — Blake (insights), Jordan (social), Morgan (paid media)
XAI_API_KEY=
GROK_MODEL=grok-3
GROK_API_BASE=https://api.x.ai/v1

# Anthropic — Nathan (Opus), content agents (Sonnet), ops agents (Haiku).
# Required for Nathan's custom LLM endpoint at /v1/chat/completions.
# When unset, all agents fall back to Grok.
ANTHROPIC_API_KEY=

# OpenAI (only used if LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Groq (only used if LLM_PROVIDER=groq)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ── Nathan's real-time tools ─────────────────────────────────────────────────
# Web search (Tavily) — get a free key at https://tavily.com.
TAVILY_API_KEY=

# Optional bearer token Tavus sends when calling our /v1/chat/completions.
# Leave empty to skip auth (Tavus can't always send auth headers).
NATHAN_LLM_API_KEY=

# ── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
UVICORN_RELOAD=false
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:4321,http://127.0.0.1:4321

# ── Project memory (Neon Postgres) ───────────────────────────────────────────
PROJECT_MEMORY_ENABLED=true
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── Microsoft Graph app (mail, OneNote, SharePoint, Teams files) ─────────────
# This is the canonical Graph identity. Do NOT add M365_TENANT_ID/CLIENT_ID/
# SECRET aliases — there is one name per concept.
MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_GRAPH_SCOPE=https://graph.microsoft.com/.default
MICROSOFT_WEBHOOK_CLIENT_STATE=
MICROSOFT_GRAPH_ALLOW_SEND=false

# OneNote target for meeting notes
ONENOTE_OWNER_MAILBOX=
ONENOTE_NOTEBOOK_ID=
ONENOTE_NOTEBOOK_NAME=RamAir
ONENOTE_SECTION_ID=
ONENOTE_SECTION_NAME=Meeting Notes

# Per-client Teams team_id / channel_id / template_path are NOT env vars
# anymore — they live in client_artifacts/<client_id>/config.yaml so
# ParlayVU can serve more than one client without env-var hacks. See
# DECISIONS.md and ARCHITECTURE.md §5.
#
# The remaining M365_FILES_* vars below are for the alternative
# SharePoint-document-library upload path (used when there's no Teams
# channel target). Most deployments leave these unset.
M365_FILES_DRIVE_ID=
M365_FILES_FOLDER_ITEM_ID=
M365_FILES_BASE_PATH=03_Deliverables/Meeting Notes

# Default client_id to bind to when Tavus calls /v1/chat/completions
# without an X-Parlayvu-Client-Id header. Each client's Tavus persona
# should send its own header; this is a safety fallback.
NATHAN_DEFAULT_CLIENT_ID=ramair

# ── Bot Framework (Teams bot identity) ───────────────────────────────────────
# Distinct from the Graph app above. Do NOT add TEAMS_BOT_* aliases.
TEAMS_APP_ID=
TEAMS_APP_PASSWORD=
TEAMS_TENANT_ID=
TEAMS_WEBHOOK_SECRET=

# ── Agent mailbox identities ─────────────────────────────────────────────────
NATHAN_MAILBOX=
ALEX_MAILBOX=
AVA_MAILBOX=
BLAKE_MAILBOX=
CASEY_MAILBOX=
CODEY_MAILBOX=
DYLAN_MAILBOX=
JORDAN_MAILBOX=
MICHAEL_MAILBOX=
MORGAN_MAILBOX=
NORA_MAILBOX=
RILEY_MAILBOX=
TAYLOR_MAILBOX=

# ── Avatar provider: Tavus CVI ───────────────────────────────────────────────
# Tavus is the chosen provider as of Phase 2 cleanup. HeyGen was evaluated and
# removed — see docs/avatar-provider-decision.md for the comparison.
TAVUS_API_KEY=
TAVUS_REPLICA_ID=
TAVUS_PERSONA_ID=
# Per-agent replica overrides (optional; defaults to TAVUS_REPLICA_ID)
TAVUS_REPLICA_ID_NATHAN=

# ── Cloudflare (Dylan site deploys) ──────────────────────────────────────────
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API=

# ── Resend (transactional email) ─────────────────────────────────────────────
RESEND_API=

# ── Azure runtime target (informational; set by IaC, not read at runtime) ────
AZURE_LOCATION=eastus2
AZURE_RESOURCE_GROUP=rg-parlayvu-demo
AZURE_CONTAINER_REGISTRY=parlayvucore
AZURE_CONTAINER_APP=parlayvu-api

# LLM provider: grok | openai | groq
LLM_PROVIDER=grok
LLM_TEMPERATURE=0.2

# xAI Grok — Blake (insights), Jordan (social), Morgan (paid media)
XAI_API_KEY=
GROK_MODEL=grok-3
GROK_API_BASE=https://api.x.ai/v1

# Anthropic — Nathan (Opus), content agents (Sonnet), ops agents (Haiku)
# When unset, all agents fall back to Grok
ANTHROPIC_API_KEY=

# OpenAI (set LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Groq (set LLM_PROVIDER=groq)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Server
HOST=0.0.0.0
PORT=8000
UVICORN_RELOAD=false
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:4321,http://127.0.0.1:4321

# Optional: Neon Postgres (app/database.py)
PROJECT_MEMORY_ENABLED=false
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Microsoft 365 / Graph
MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_GRAPH_SCOPE=https://graph.microsoft.com/.default
MICROSOFT_WEBHOOK_CLIENT_STATE=
MICROSOFT_GRAPH_ALLOW_SEND=false
ONENOTE_OWNER_MAILBOX=
ONENOTE_NOTEBOOK_ID=
ONENOTE_NOTEBOOK_NAME=RamAir
ONENOTE_SECTION_ID=
ONENOTE_SECTION_NAME=Meeting Notes
M365_FILES_TEAM_ID=
M365_FILES_CHANNEL_ID=
M365_FILES_DRIVE_ID=
M365_FILES_FOLDER_ITEM_ID=
M365_FILES_BASE_PATH=03_Deliverables/Meeting Notes
M365_FILES_MEETING_NOTES_TEMPLATE_PATH=00_Client_Brief/Templates/RamAir Meeting Notes Template.docx

# Microsoft Teams front door
TEAMS_APP_ID=
TEAMS_APP_PASSWORD=
TEAMS_TENANT_ID=
TEAMS_WEBHOOK_SECRET=

# Agent mailbox identities
NATHAN_MAILBOX=
ALEX_MAILBOX=
AVA_MAILBOX=
BLAKE_MAILBOX=
CASEY_MAILBOX=
CODEY_MAILBOX=
DYLAN_MAILBOX=
JORDAN_MAILBOX=
MICHAEL_MAILBOX=
MORGAN_MAILBOX=
NORA_MAILBOX=
RILEY_MAILBOX=
TAYLOR_MAILBOX=

# HeyGen LiveAvatar
HEYGEN_API_KEY=
HEYGEN_BASE_URL=https://api.heygen.com
HEYGEN_WEBHOOK_SECRET=
HEYGEN_NATHAN_AVATAR_ID=
HEYGEN_ALEX_AVATAR_ID=
HEYGEN_AVA_AVATAR_ID=
HEYGEN_BLAKE_AVATAR_ID=
HEYGEN_CASEY_AVATAR_ID=
HEYGEN_CODEY_AVATAR_ID=
HEYGEN_DYLAN_AVATAR_ID=
HEYGEN_JORDAN_AVATAR_ID=
HEYGEN_MICHAEL_AVATAR_ID=
HEYGEN_MORGAN_AVATAR_ID=
HEYGEN_NORA_AVATAR_ID=
HEYGEN_RILEY_AVATAR_ID=
HEYGEN_TAYLOR_AVATAR_ID=

# Azure runtime target
AZURE_LOCATION=eastus2
AZURE_RESOURCE_GROUP=rg-parlayvu-demo
AZURE_CONTAINER_REGISTRY=
AZURE_CONTAINER_APP=
AZURE_CONTAINER_ENV=

# AWS runtime target (optional portability path)
AWS_REGION=us-east-2
AWS_ECS_CLUSTER=
AWS_ECS_SERVICE=
AWS_SECRETS_PREFIX=/parlayvu/prod/

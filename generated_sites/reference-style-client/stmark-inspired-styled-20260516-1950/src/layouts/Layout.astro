---
export interface Props {
  title: string;
  description?: string;
}
const { title, description } = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <style is:global>
    :root {
      color-scheme: light;
      --cream: #f5efe4;
      --ink: #20352f;
      --muted: #52645d;
      --rust: #d9904f;
      --rust-dark: #a25f2b;
      --sage: #7f9b8f;
      --line: rgba(32, 53, 47, 0.12);
      --white: #ffffff;
    }

    * {
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      margin: 0;
      background: var(--cream);
      color: var(--ink);
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      line-height: 1.5;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    main {
      min-height: 100vh;
      overflow: hidden;
    }

    header {
      width: min(1120px, calc(100% - 48px));
      margin: 0 auto;
      padding: 28px 0;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 24px;
    }

    header > a {
      font-size: 1.45rem;
      font-weight: 900;
      letter-spacing: -0.04em;
    }

    nav {
      display: flex;
      align-items: center;
      gap: 28px;
      color: var(--muted);
      font-size: 0.74rem;
      font-weight: 800;
      letter-spacing: 0.16em;
      text-transform: uppercase;
    }

    section {
      padding: 80px 24px;
    }

    section:first-of-type {
      padding-top: 48px;
      padding-bottom: 96px;
    }

    section:first-of-type > div,
    section > div {
      width: min(1120px, 100%);
      margin: 0 auto;
    }

    section:first-of-type > div {
      display: grid;
      grid-template-columns: 1.05fr 0.95fr;
      align-items: center;
      gap: 56px;
    }

    h1,
    h2,
    h3,
    p {
      margin-top: 0;
    }

    h1 {
      margin-bottom: 28px;
      max-width: 820px;
      font-size: clamp(3.2rem, 7vw, 6.8rem);
      line-height: 0.94;
      letter-spacing: -0.065em;
      font-weight: 950;
    }

    h2 {
      margin-bottom: 0;
      max-width: 760px;
      font-size: clamp(2.3rem, 4vw, 4.3rem);
      line-height: 1;
      letter-spacing: -0.045em;
      font-weight: 950;
    }

    h3 {
      margin-bottom: 14px;
      font-size: 1.55rem;
      line-height: 1.1;
      letter-spacing: -0.03em;
      font-weight: 900;
    }

    p {
      color: var(--muted);
    }

    p[class*="uppercase"],
    section:first-of-type p:first-child,
    #start > div > p,
    #message p:first-child,
    #assets > div > p,
    #subscribe p:first-child {
      margin-bottom: 18px;
      color: var(--rust-dark);
      font-size: 0.78rem;
      font-weight: 900;
      letter-spacing: 0.22em;
      text-transform: uppercase;
    }

    section:first-of-type h1 + p {
      max-width: 650px;
      font-size: 1.22rem;
      line-height: 1.75;
    }

    section:first-of-type a,
    #message a,
    #subscribe a {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      margin-right: 12px;
      margin-top: 18px;
      border-radius: 999px;
      padding: 15px 26px;
      background: var(--ink);
      color: var(--white);
      font-weight: 850;
      box-shadow: 0 16px 35px rgba(32, 53, 47, 0.16);
    }

    section:first-of-type a + a {
      background: transparent;
      color: var(--ink);
      border: 2px solid rgba(32, 53, 47, 0.18);
      box-shadow: none;
    }

    section:first-of-type > div > div:last-child {
      overflow: hidden;
      border-radius: 32px;
      background: var(--ink);
      box-shadow: 0 26px 70px rgba(32, 53, 47, 0.22);
    }

    section:first-of-type > div > div:last-child > div:first-child {
      min-height: 390px;
      padding: 32px;
      display: flex;
      align-items: flex-end;
      background:
        radial-gradient(circle at 15% 20%, rgba(255,255,255,0.48), transparent 24%),
        linear-gradient(135deg, var(--rust), #f3d7a6 54%, var(--sage));
    }

    section:first-of-type > div > div:last-child > div:first-child > div {
      width: 100%;
      border: 1px solid rgba(255,255,255,0.45);
      border-radius: 24px;
      padding: 28px;
      background: rgba(255,255,255,0.78);
      backdrop-filter: blur(12px);
    }

    section:first-of-type > div > div:last-child p {
      margin-bottom: 0;
      color: var(--ink);
    }

    section:first-of-type > div > div:last-child > div:last-child {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 24px;
      padding: 24px;
    }

    section:first-of-type > div > div:last-child > div:last-child p {
      color: rgba(255,255,255,0.76);
    }

    section:first-of-type > div > div:last-child > div:last-child p + p {
      color: var(--white);
      font-weight: 800;
    }

    section:nth-of-type(2) {
      border-top: 1px solid var(--line);
      border-bottom: 1px solid var(--line);
      background: rgba(255,255,255,0.5);
      padding: 34px 24px;
    }

    section:nth-of-type(2) > div {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 28px;
      text-align: center;
    }

    section:nth-of-type(2) p:first-child {
      margin-bottom: 4px;
      color: var(--ink);
      font-size: 2.1rem;
      font-weight: 950;
    }

    #start > div > div,
    #assets > div > div {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 24px;
      margin-top: 44px;
    }

    #start a,
    #assets div div div {
      display: block;
      min-height: 220px;
      border-radius: 28px;
      padding: 30px;
      background: rgba(255,255,255,0.82);
      box-shadow: 0 1px 0 rgba(32, 53, 47, 0.08), 0 18px 45px rgba(32, 53, 47, 0.08);
      transition: transform 180ms ease, box-shadow 180ms ease;
    }

    #start a:hover {
      transform: translateY(-4px);
      box-shadow: 0 24px 60px rgba(32, 53, 47, 0.13);
    }

    #start a p:last-child {
      margin-top: 26px;
      color: var(--rust-dark);
      font-weight: 900;
    }

    #message {
      background: var(--ink);
      color: var(--white);
    }

    #message > div {
      display: grid;
      grid-template-columns: 0.9fr 1.1fr;
      gap: 56px;
      align-items: center;
    }

    #message h2 {
      color: var(--white);
    }

    #message > div > div:last-child {
      border-radius: 32px;
      padding: 34px;
      background: var(--white);
      color: var(--ink);
    }

    #message a {
      background: var(--rust);
    }

    #assets > div > div {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    #subscribe {
      padding-top: 24px;
    }

    #subscribe > div {
      border-radius: 32px;
      padding: 64px 40px;
      background: var(--rust);
      color: var(--white);
      text-align: center;
    }

    #subscribe h2,
    #subscribe p {
      margin-left: auto;
      margin-right: auto;
      color: var(--white);
    }

    #subscribe p:last-of-type {
      max-width: 700px;
      color: rgba(255,255,255,0.86);
      font-size: 1.12rem;
    }

    @media (max-width: 900px) {
      nav {
        display: none;
      }

      section:first-of-type > div,
      #message > div {
        grid-template-columns: 1fr;
      }

      #start > div > div,
      #assets > div > div,
      section:nth-of-type(2) > div {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>
<body>
  <slot />
</body>
</html>

---
import Layout from '../layouts/Layout.astro';
const pageTitle = "ParlayVU.ai | Agentic Content Workflow";
const pageDescription = "AI-powered content repurposing landing page";

const caseStudies = [
  {
    eyebrow: "RamAir / ramair.co",
    title: "RamAir: Straight from the Hart",
    summary:
      "ParlayVU launched a weekly video podcast and turns each episode into a coordinated content engine across video, clips, social publishing, website updates, transcript insights, case studies, and product sell sheets.",
    outputs: [
      "Published video on YouTube and ramair.co",
      "Short clips for YouTube, Instagram, and TikTok",
      "Planned daily posts for LinkedIn, Facebook, Instagram, and X after RamAir's white paper timing",
      "Transcript insights for positiveairductcleaning.org quotes, FAQs, and education",
      "PDF case studies for marketing and sales conversations",
      "Product sell sheets tied to each episode's topics",
    ],
    links: [
      { label: "Straight from the Hart playlist", href: "https://www.youtube.com/playlist?list=PLfwEIpYOOZ7IGdzFAhfPHjdPBi9a_ONDY" },
      { label: "YouTube Shorts playlist", href: "https://www.youtube.com/playlist?list=PLfwEIpYOOZ7Is0JshJZ5Elnomg9H0GvWk" },
      { label: "RamAir blogs", href: "https://ramair.co/blogs/" },
      { label: "Positive Air Duct Cleaning", href: "https://www.positiveairductcleaning.org/" },
      { label: "Instagram", href: "https://www.instagram.com/ramairinternationalinc/" },
      { label: "TikTok", href: "https://www.tiktok.com/@ramairinternational" },
      { label: "Facebook", href: "https://www.facebook.com/ramairint" },
    ],
  },
];
---

<Layout title={pageTitle} description={pageDescription}>
  <main class="parlay-shell">
    <header class="mx-auto flex max-w-6xl items-center justify-between px-6 py-7">
      <a href="#" class="brand-link" aria-label="ParlayVU home">
        <img src="/brand/parlayvu-logo-dark.png" alt="ParlayVU" class="brand-logo" />
      </a>
      <nav class="hidden items-center gap-8 text-sm font-semibold uppercase tracking-[0.2em] text-[#52645d] md:flex">
        <a href="#start">Platform</a>
        <a href="#case-studies">Case Studies</a>
        <a href="#assets">Team</a>
        <a href="#subscribe">Start</a>
      </nav>
    </header>

    <section class="px-6 pb-16 pt-10 sm:pb-24">
      <div class="mx-auto grid max-w-6xl items-center gap-12 lg:grid-cols-[1.05fr_0.95fr]">
        <div class="min-w-0">
          <p class="mb-5 text-sm font-bold uppercase tracking-[0.28em] text-[#a25f2b]">Your Agentic Growth Team</p>
          <h1 class="hero-headline" aria-label="Parlay Your Content Into Exponential Multi-Channel Reach with AI Agents.">
            <span>Parlay Your Content</span>
            <span>Into Exponential</span>
            <span>Multi-Channel Reach</span>
            <span>with AI Agents.</span>
          </h1>
          <p class="mt-7 max-w-2xl text-xl leading-8 text-[#52645d]">
            Turn video podcasts into threads, ads, emails, reels, shorts, and more, intelligently repurposed and optimized across every platform.
          </p>
          <div class="mt-10 flex flex-col gap-4 sm:flex-row">
            <a href="#start" class="rounded-full bg-[#20352f] px-8 py-4 text-center font-bold text-white shadow-lg shadow-black/10 transition hover:bg-[#304d45]">
              Explore The Platform
            </a>
            <a href="#assets" class="rounded-full border-2 border-[#20352f]/20 px-8 py-4 text-center font-bold text-[#20352f] transition hover:border-[#20352f]">
              Meet Your Agents
            </a>
          </div>
        </div>
        <article class="hero-nathan-card">
          <button class="video-trigger leader-video-trigger" type="button" data-video-src="/videos/nathan-intro.mp4" data-agent-name="Nathan Ellis" data-agent-role="Lead Orchestrator Agent">
            <img src="/agents/Nathan.png" alt="Nathan Ellis" loading="eager" />
            <span>Play Nathan's intro</span>
          </button>
          <div>
            <p>Lead Orchestrator Agent</p>
            <h2>Nathan Ellis</h2>
            <span>Coordinates strategy, agent routing, approval gates, and final delivery.</span>
          </div>
        </article>
      </div>
    </section>

    <section id="start" class="px-6 py-20">
      <div class="mx-auto max-w-6xl">
        <p class="text-sm font-bold uppercase tracking-[0.28em] text-[#a25f2b]">The Platform</p>
        <h2 class="mt-4 max-w-3xl text-4xl font-semibold tracking-tight sm:text-5xl">Agent workflow with editorial discipline.</h2>
        <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-4">
          <a href="#assets" class="rounded-[1.75rem] bg-white p-7 shadow-sm transition hover:-translate-y-1 hover:shadow-xl">
            <h3 class="text-2xl font-semibold">Brief Intake</h3>
            <p class="mt-4 text-[#52645d]">Capture audience, offer, source material, brand voice, and approval constraints.</p>
            <p class="mt-6 font-bold text-[#a25f2b]">Define work -></p>
          </a>
          <a href="#assets" class="rounded-[1.75rem] bg-white p-7 shadow-sm transition hover:-translate-y-1 hover:shadow-xl">
            <h3 class="text-2xl font-semibold">Agent Routing</h3>
            <p class="mt-4 text-[#52645d]">Nathan selects the right specialist, keeps handoffs visible, and reduces drift.</p>
            <p class="mt-6 font-bold text-[#a25f2b]">Route tasks -></p>
          </a>
          <a href="#assets" class="rounded-[1.75rem] bg-white p-7 shadow-sm transition hover:-translate-y-1 hover:shadow-xl">
            <h3 class="text-2xl font-semibold">Asset Factory</h3>
            <p class="mt-4 text-[#52645d]">Generate pages, campaigns, scripts, social cuts, and distribution-ready copy.</p>
            <p class="mt-6 font-bold text-[#a25f2b]">Create assets -></p>
          </a>
          <a href="#subscribe" class="rounded-[1.75rem] bg-white p-7 shadow-sm transition hover:-translate-y-1 hover:shadow-xl">
            <h3 class="text-2xl font-semibold">Launch Loop</h3>
            <p class="mt-4 text-[#52645d]">Build, deploy, inspect, refine, and preserve a clear path to production.</p>
            <p class="mt-6 font-bold text-[#a25f2b]">Ship work -></p>
          </a>
        </div>
      </div>
    </section>

    <section id="case-studies" class="case-studies-section">
      <div>
        <p>ParlayVU in the field</p>
        <div class="case-studies-header">
          <h2>How RamAir turns one weekly podcast into a content engine.</h2>
          <p>
            The first client story in a reusable case study library built to show how ParlayVU compounds source material into channel reach.
          </p>
        </div>
        <div class="case-study-grid">
          {caseStudies.map((study) => (
            <article class="case-study-card">
              <div class="case-study-card__intro">
                <p>{study.eyebrow}</p>
                <h3>{study.title}</h3>
                <span>{study.summary}</span>
              </div>
              <ul class="case-study-outputs" aria-label={`${study.title} outputs`}>
                {study.outputs.map((output) => (
                  <li>{output}</li>
                ))}
              </ul>
              <div class="case-study-links" aria-label={`${study.title} links`}>
                {study.links.map((link) => (
                  <a href={link.href} target="_blank" rel="noreferrer">{link.label}</a>
                ))}
              </div>
            </article>
          ))}
          <aside class="case-study-testimonial" aria-label="David Hart testimonial">
            <img src="/case-studies/ramair-david-hart.png" alt="David Hart of RamAir" loading="lazy" />
            <div>
              <p>Client testimonial</p>
              <blockquote>
                "The ParlayVU team is amazing. They took my podcast idea and turned it into a turnkey marketing cadence. With one show, I have a week's worth of quality content distributed on my site, my industry site, and across my socials. And we're seeing a significant uptick in sales leads already."
              </blockquote>
              <cite>David Hart, RamAir</cite>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <section id="assets" class="team-grid-section">
      <div>
        <p>Specialist Agents</p>
        <h2>The specialist team Nathan coordinates.</h2>
        <div class="team-grid">
          <article class="agent-card">
            <button class="video-trigger" type="button" data-video-src="/videos/alex-intro.mp4" data-agent-name="Alex Rivera" data-agent-role="Visuals & Design">
              <img src="/agents/Alex.png" alt="Alex Rivera" loading="lazy" />
              <span>Play intro</span>
            </button>
            <p>Visuals & Design</p>
            <h3>Alex Rivera</h3>
            <span>Shapes visual direction, brand systems, creative assets, and presentation polish.</span>
          </article>
          <article class="agent-card">
            <button class="video-trigger" type="button" data-video-src="/videos/ava-intro.mp4" data-agent-name="Ava Hosseini" data-agent-role="Content Writing">
              <img src="/agents/Ava.png" alt="Ava Hosseini" loading="lazy" />
              <span>Play intro</span>
            </button>
            <p>Content Writing</p>
            <h3>Ava Hosseini</h3>
            <span>Turns strategy into clear website copy, articles, emails, ads, social captions, and scripts.</span>
          </article>
          <article class="agent-card">
            <button class="video-trigger" type="button" data-video-src="/videos/dylan-intro.mp4" data-agent-name="Dylan Brooks" data-agent-role="Web & Deployment">
              <img src="/agents/Dylan.png" alt="Dylan Brooks" loading="lazy" />
              <span>Play intro</span>
            </button>
            <p>Web & Deployment</p>
            <h3>Dylan Brooks</h3>
            <span>Owns website generation, deployment, platform SEO, domain routing, and release verification.</span>
          </article>
          <article class="agent-card">
            <button class="video-trigger" type="button" data-video-src="/videos/casey-intro.mp4" data-agent-name="Casey Johnson" data-agent-role="Operations">
              <img src="/agents/Casey.png" alt="Casey Johnson" loading="lazy" />
              <span>Play intro</span>
            </button>
            <p>Operations</p>
            <h3>Casey Johnson</h3>
            <span>Keeps task flow, production standards, handoffs, and quality checks moving cleanly.</span>
          </article>
          <article class="agent-card">
            <button class="video-trigger" type="button" data-video-src="/videos/riley-intro.mp4" data-agent-name="Riley Thompson" data-agent-role="Distribution">
              <img src="/agents/Riley.png" alt="Riley Thompson" loading="lazy" />
              <span>Play intro</span>
            </button>
            <p>Distribution</p>
            <h3>Riley Thompson</h3>
            <span>Adapts assets for channels, posting workflows, and distribution timing.</span>
          </article>
          <article class="agent-card">
            <button class="video-trigger" type="button" data-video-src="/videos/blake-intro.mp4" data-agent-name="Blake Quinn" data-agent-role="Research & Analytics">
              <img src="/agents/Blake.png" alt="Blake Quinn" loading="lazy" />
              <span>Play intro</span>
            </button>
            <p>Research & Analytics</p>
            <h3>Blake Quinn</h3>
            <span>Finds market context, source material, positioning angles, and useful campaign inputs.</span>
          </article>
          <article class="agent-card">
            <button class="video-trigger" type="button" data-video-src="/videos/jordan-intro.mp4" data-agent-name="Jordan McKenney" data-agent-role="Publishing">
              <img src="/agents/Jordan.png" alt="Jordan McKenney" loading="lazy" />
              <span>Play intro</span>
            </button>
            <p>Publishing</p>
            <h3>Jordan McKenney</h3>
            <span>Coordinates publishing requirements, channel readiness, and platform-specific delivery.</span>
          </article>
          <article class="agent-card">
            <button class="video-trigger" type="button" data-video-src="/videos/nora-intro.mp4" data-agent-name="Nora Russo" data-agent-role="Partnerships">
              <img src="/agents/Nora.png" alt="Nora Russo" loading="lazy" />
              <span>Play intro</span>
            </button>
            <p>Partnerships</p>
            <h3>Nora Russo</h3>
            <span>Develops partnership, affiliate, influencer, PR, and co-marketing opportunities.</span>
          </article>
          <article class="agent-card">
            <button class="video-trigger" type="button" data-video-src="/videos/morgan-intro.mp4" data-agent-name="Morgan Patel" data-agent-role="Paid Media">
              <img src="/agents/Morgan.png" alt="Morgan Patel" loading="lazy" />
              <span>Play intro</span>
            </button>
            <p>Paid Media</p>
            <h3>Morgan Patel</h3>
            <span>Tracks performance, reads campaign signals, and turns results into practical next steps.</span>
          </article>
          <article class="agent-card">
            <button class="video-trigger" type="button" data-video-src="/videos/michael-intro.mp4" data-agent-name="Michael Chen" data-agent-role="Offers & Sales">
              <img src="/agents/Michael.png" alt="Michael Chen" loading="lazy" />
              <span>Play intro</span>
            </button>
            <p>Offers & Sales</p>
            <h3>Michael Chen</h3>
            <span>Refines offers, conversion paths, client promises, and sales-aligned campaign structure.</span>
          </article>
          <article class="agent-card">
            <button class="video-trigger" type="button" data-video-src="/videos/codey-intro.mp4" data-agent-name="Codey Miner" data-agent-role="Automation & Systems">
              <img src="/agents/Codey.png" alt="Codey Miner" loading="lazy" />
              <span>Play intro</span>
            </button>
            <p>Automation & Systems</p>
            <h3>Codey Miner</h3>
            <span>Builds the technical systems, integrations, and workflow automation behind execution.</span>
          </article>
          <article class="agent-card">
            <button class="video-trigger" type="button" data-video-src="/videos/taylor-intro.mp4" data-agent-name="Taylor Kim" data-agent-role="Client Success">
              <img src="/agents/Taylor.png" alt="Taylor Kim" loading="lazy" />
              <span>Play intro</span>
            </button>
            <p>Client Success</p>
            <h3>Taylor Kim</h3>
            <span>Keeps client needs, feedback, approvals, and delivery expectations visible.</span>
          </article>
        </div>
      </div>
    </section>

    <section id="subscribe" class="px-6 pb-20">
      <div class="mx-auto max-w-6xl rounded-[2rem] bg-[#d9904f] p-10 text-center text-white sm:p-16">
        <p class="text-sm font-bold uppercase tracking-[0.28em] text-white/75">Ready to operationalize your content?</p>
        <h2 class="cta-headline mt-4 text-4xl font-medium tracking-tight sm:text-5xl">
          <span>VU is your brand.</span>
          <span>Parlay your VU.</span>
        </h2>
        <p class="cta-copy mx-auto max-w-2xl text-lg text-white/85">ParlayVU combines premium consulting mindset with agentic workflow production.</p>
        <a href="mailto:hello@parlayvu.ai" class="mt-8 inline-flex rounded-full bg-[#20352f] px-10 py-4 font-bold text-white transition hover:bg-[#304d45]">
          Book a Strategy Call
        </a>
      </div>
    </section>

    <footer class="site-footer">
      <div>
        <a href="#" class="brand-link" aria-label="ParlayVU home">
          <img src="/brand/parlayvu-logo-dark.png" alt="ParlayVU" class="brand-logo" loading="lazy" />
        </a>
        <p>Agentic content infrastructure for teams that want strategy, production, and deployment in one operating loop.</p>
        <nav aria-label="Footer navigation">
          <a href="#start">Platform</a>
          <a href="#case-studies">Case Studies</a>
          <a href="#assets">Agents</a>
          <a href="#subscribe">Contact</a>
        </nav>
      </div>
    </footer>

    <div class="video-modal" data-video-modal hidden>
      <button class="video-modal__backdrop" type="button" data-video-close aria-label="Close video"></button>
      <section class="video-modal__dialog" role="dialog" aria-modal="true" aria-labelledby="video-modal-title">
        <div class="video-modal__header">
          <p data-video-role>Agent Role</p>
          <button type="button" data-video-close aria-label="Close video">Close</button>
        </div>
        <h2 id="video-modal-title">Agent Name</h2>
        <video data-video-player controls playsinline preload="metadata"></video>
      </section>
    </div>
  </main>
</Layout>

<script>
  const modal = document.querySelector('[data-video-modal]');
  const video = document.querySelector('[data-video-player]');
  const title = document.querySelector('#video-modal-title');
  const role = document.querySelector('[data-video-role]');
  const triggers = document.querySelectorAll('[data-video-src]');
  const closeButtons = document.querySelectorAll('[data-video-close]');

  const closeModal = () => {
    if (!(modal instanceof HTMLElement) || !(video instanceof HTMLVideoElement)) return;
    video.pause();
    video.removeAttribute('src');
    video.load();
    modal.hidden = true;
    document.body.classList.remove('modal-open');
  };

  triggers.forEach((trigger) => {
    trigger.addEventListener('click', () => {
      if (!(modal instanceof HTMLElement) || !(video instanceof HTMLVideoElement)) return;
      const source = trigger.getAttribute('data-video-src');
      const agentName = trigger.getAttribute('data-agent-name') || 'Agent';
      const agentRole = trigger.getAttribute('data-agent-role') || 'Agent';
      if (!source) return;

      if (role) role.textContent = agentRole;
      if (title) title.textContent = agentName;
      video.src = source;
      modal.hidden = false;
      document.body.classList.add('modal-open');
      video.play().catch(() => {
        video.controls = true;
      });
    });
  });

  closeButtons.forEach((button) => {
    button.addEventListener('click', closeModal);
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') closeModal();
  });
</script>

---
export interface Feature {
  icon?: string;
  title: string;
  description: string;
}

interface Props {
  title?: string;
  features: Feature[];
}

const { title = "What We Deliver", features } = Astro.props;
---

<section class="py-16 md:py-20 border-t border-zinc-800">
  <div class="max-w-6xl mx-auto px-6">
    {title && (
      <h2 class="text-3xl md:text-4xl font-semibold tracking-tight mb-12">
        {title}
      </h2>
    )}

    <div class="grid grid-cols-1 md:grid-cols-3 gap-x-8 gap-y-10">
      {features.map((feature) => (
        <div>
          {feature.icon && (
            <div class="mb-5 text-3xl">{feature.icon}</div>
          )}
          <h3 class="font-semibold text-xl tracking-tight mb-3">{feature.title}</h3>
          <p class="text-[15px] leading-relaxed text-zinc-400">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
